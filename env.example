# AK Solar - SMTP ve Form Ayarları
# Bu dosyayı .env olarak kopyalayın ve değerlerinizi girin

# SMTP Ayarları
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AK Solar <noreply@aksolar.com>

# Form Ayarları
FORM_RECIPIENT=ak@ak-pro.com
FORM_SUBJECT=Yeni Teklif Talebi - AK Solar Demo
FORM_REPLY_TO=ak@ak-pro.com

# Google reCAPTCHA (Opsiyonel)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Google Analytics (Opsiyonel)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel (Opsiyonel)
FB_PIXEL_ID=XXXXXXXXXX

# API Anahtarları (Opsiyonel)
WEATHER_API_KEY=your-weather-api-key
ENERGY_API_KEY=your-energy-api-key

# Güvenlik Ayarları
CSRF_TOKEN_SECRET=your-csrf-secret-key
SESSION_SECRET=your-session-secret-key

# Dosya Yükleme Ayarları
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp,pdf

# E-posta Şablonları
EMAIL_TEMPLATE_PATH=assets/templates/email/
EMAIL_SIGNATURE=AK Solar Enerji\nTürkiye'nin Güneş Enerjisi Partneri

# Bildirim Ayarları
NOTIFICATION_EMAIL=ak@ak-pro.com
SMS_API_KEY=your-sms-api-key
SMS_SENDER=AKSOLAR

# Ödeme Ayarları (Opsiyonel)
PAYMENT_API_KEY=your-payment-api-key
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# Çevrimdışı Ayarları
OFFLINE_MODE=false
CACHE_DURATION=3600

# Debug Modu
DEBUG_MODE=false
LOG_LEVEL=info

# Veritabanı Ayarları (Opsiyonel)
DB_HOST=localhost
DB_NAME=ak_solar
DB_USER=root
DB_PASS=password

# Redis Ayarları (Opsiyonel)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CDN Ayarları (Opsiyonel)
CDN_URL=https://cdn.aksolar.com
CDN_API_KEY=your-cdn-api-key

# Sosyal Medya API'leri (Opsiyonel)
TWITTER_API_KEY=your-twitter-api-key
LINKEDIN_API_KEY=your-linkedin-api-key
INSTAGRAM_API_KEY=your-instagram-api-key

# Çeviri Ayarları (Opsiyonel)
DEFAULT_LANGUAGE=tr
SUPPORTED_LANGUAGES=tr,en,de

# Performans Ayarları
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
MINIFY_HTML=true
MINIFY_CSS=true
MINIFY_JS=true

# Güvenlik Ayarları
ENABLE_HTTPS_REDIRECT=true
ENABLE_CSP=true
ENABLE_HSTS=true
ENABLE_XSS_PROTECTION=true

# Monitoring Ayarları (Opsiyonel)
MONITORING_API_KEY=your-monitoring-api-key
ERROR_REPORTING_EMAIL=ak@ak-pro.com

# Backup Ayarları (Opsiyonel)
BACKUP_EMAIL=ak@ak-pro.com
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Özelleştirme Ayarları
COMPANY_NAME=AK Solar
COMPANY_LOGO=assets/images/logo.png
COMPANY_FAVICON=assets/images/favicon.ico
COMPANY_COLOR_PRIMARY=#0F9D58
COMPANY_COLOR_SECONDARY=#4285F4

# E-posta Doğrulama Ayarları
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_EXPIRY=24

# SMS Doğrulama Ayarları (Opsiyonel)
SMS_VERIFICATION_REQUIRED=false
SMS_VERIFICATION_EXPIRY=10

# Dosya Yükleme Kısıtlamaları
MAX_IMAGES_PER_PROJECT=10
MAX_PROJECT_FILES=50
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
ALLOWED_DOCUMENT_FORMATS=pdf,doc,docx

# SEO Ayarları
SITE_TITLE=AK Solar | Güneş Enerjisi Çözümleri
SITE_DESCRIPTION=Türkiye'nin önde gelen güneş enerjisi firması
SITE_KEYWORDS=güneş enerjisi,GES kurulumu,solar panel
SITE_AUTHOR=a.koc
SITE_LANGUAGE=tr

# Sosyal Medya URL'leri (Demo için boş bırakıldı)
SOCIAL_FACEBOOK=
SOCIAL_TWITTER=
SOCIAL_LINKEDIN=
SOCIAL_INSTAGRAM=

# İletişim Bilgileri (Demo için örnek)
CONTACT_PHONE=+90 212 555 0123
CONTACT_MOBILE=+90 532 123 4567
CONTACT_EMAIL=ak@ak-pro.com
CONTACT_ADDRESS=Merkez Mahallesi, Solar Caddesi No:123, Şişli/İstanbul

# Çalışma Saatleri
WORKING_HOURS_MONDAY=09:00-18:00
WORKING_HOURS_TUESDAY=09:00-18:00
WORKING_HOURS_WEDNESDAY=09:00-18:00
WORKING_HOURS_THURSDAY=09:00-18:00
WORKING_HOURS_FRIDAY=09:00-18:00
WORKING_HOURS_SATURDAY=09:00-14:00
WORKING_HOURS_SUNDAY=Kapalı

# Hizmet Bölgeleri
SERVICE_REGIONS=İstanbul,İzmir,Ankara,Antalya,Bursa,Adana,Konya

# Garanti Ayarları
WARRANTY_YEARS=10
WARRANTY_COVERAGE=Panel,İnverter,Montaj
WARRANTY_EXCLUSIONS=Doğal afetler,İnsan kaynaklı hasarlar

# Fiyatlandırma Ayarları
CURRENCY=TRY
CURRENCY_SYMBOL=₺
PRICE_DISPLAY_FORMAT=₺X,XXX
DISCOUNT_PERCENTAGE=5

# Müşteri Desteği (Demo için örnek)
SUPPORT_PHONE=+90 212 555 0124
SUPPORT_EMAIL=ak@ak-pro.com
SUPPORT_HOURS=7/24
SUPPORT_RESPONSE_TIME=2 saat

# Kalite Sertifikaları
CERTIFICATION_ISO=ISO 9001:2015
CERTIFICATION_CE=CE Marking
CERTIFICATION_TSE=TSE Marking

# Ortaklık Bilgileri
PARTNER_SOLAR_PANELS=LG,SunPower,Panasonic
PARTNER_INVERTERS=SMA,Fronius,SolarEdge
PARTNER_MOUNTING=Schletter,Esdec,Clenergy

# Proje İstatistikleri
TOTAL_PROJECTS=500
TOTAL_CAPACITY=50
TOTAL_CUSTOMERS=1000
TOTAL_SAVINGS=1000000

# Teknik Özellikler
PANEL_EFFICIENCY=0.85
SYSTEM_LIFESPAN=25
MAINTENANCE_FREQUENCY=Yıllık
MONITORING_TYPE=Uzaktan

# Çevre Bilgileri
CO2_REDUCTION_PER_KW=0.5
TREE_EQUIVALENT_PER_KW=25
ANNUAL_ENERGY_PRODUCTION_PER_KW=1400

# Yasal Uyumluluk
COMPLIANCE_TEIAŞ=TEİAŞ Yönetmeliklerine Uygun
COMPLIANCE_EPDK=EPDK Lisanslı
COMPLIANCE_ISO=ISO Standartlarına Uygun

# Güvenlik Sertifikaları
SECURITY_SSL=SSL Sertifikalı
SECURITY_FIREWALL=Güvenlik Duvarı
SECURITY_BACKUP=Otomatik Yedekleme
SECURITY_MONITORING=7/24 İzleme

---

# Kullanım Talimatları:
# 1. Bu dosyayı .env olarak kopyalayın
# 2. Gerekli değerleri girin
# 3. Hassas bilgileri güvenli tutun
# 4. .env dosyasını .gitignore'a ekleyin
# 5. Sunucuda .env dosyasını yükleyin

# Önemli Notlar:
# - SMTP_PASS için Gmail App Password kullanın
# - API anahtarlarını güvenli tutun
# - Üretim ortamında DEBUG_MODE=false yapın
# - Düzenli olarak yedek alın 